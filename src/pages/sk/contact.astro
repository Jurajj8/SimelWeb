---
import Layout from '../../layouts/Layout.astro';
import ContactSection from '../../components/ContactSection.astro';
import HeroSectionContact from '../../components/HeroSectionContact.astro';
import { translations } from '../../locales.ts';

const t = translations.sk;
---

<Layout title={t.seo.contact.title} description={t.seo.contact.description} keywords={t.seo.contact.keywords}>
	<main class="w-full mb-40">
		<HeroSectionContact
		    showButtons={false}
			customClass="py-20 h-[75vh]"
		/>
        <ContactSection />
	</main>
</Layout>
